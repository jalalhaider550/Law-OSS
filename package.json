{
  "name": "law-oss",
  "private": true,
  "packageManager": "npm@10.0.0",
  "engines": {
    "node": ">=22.0.0"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev --parallel",
    "build": "turbo run build",
    "deploy": "bash scripts/deploy.sh",
    "setup": "bash scripts/setup.sh",
    "db:push": "cd packages/db && npx prisma db push",
    "db:migrate": "cd packages/db && npx prisma migrate dev",
    "db:migrate:prod": "cd packages/db && npx prisma migrate deploy",
    "db:studio": "cd packages/db && npx prisma studio",
    "db:generate": "cd packages/db && npx prisma generate"
  },
  "devDependencies": {
    "dotenv-cli": "^7.0.0",
    "turbo": "^2.0.0",
    "typescript": "^5.0.0"
  },
  "dependencies": {
    "pdfjs-dist": "4.10.38",
    "three": "^0.167.1"
  }
}
