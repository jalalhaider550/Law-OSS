# ════════════════════════════════════════
# Law OSS — Environment Variables
# Copy this file to .env and fill in values
# NEVER commit .env to git
# ════════════════════════════════════════

# ── SUPABASE ─────────────────────────────
# Get from: supabase.com → your project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── DATABASE ─────────────────────────────
# Get from: supabase.com → your project → Settings → Database → Connection string
# Use the "URI" format. Add ?pgbouncer=true for production.
DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true
DIRECT_DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres

# ── ENCRYPTION ───────────────────────────
# Generate with: openssl rand -hex 32
# Keep this secret — losing it means stored API keys cannot be decrypted
ENCRYPTION_SECRET=your-64-character-hex-string-here

# ── API ───────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:3001
PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# ── UPSTASH REDIS (optional for local) ───
# Get from: upstash.com → Create database → REST API
# If not set, in-memory rate limiting is used instead
UPSTASH_REDIS_REST_URL=https://...upstash.io
UPSTASH_REDIS_REST_TOKEN=...
