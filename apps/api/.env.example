# ── Database ──────────────────────────────────────────────────────────────────
# Your Supabase project's Postgres connection string (Settings → Database → URI)
DATABASE_URL=your_supabase_postgres_url

# ── Supabase ──────────────────────────────────────────────────────────────────
SUPABASE_URL=your_supabase_project_url
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# ── Encryption ────────────────────────────────────────────────────────────────
# Any random 32-character string — used to encrypt stored API keys
# Generate one: node -e "console.log(require('crypto').randomBytes(16).toString('hex'))"
ENCRYPTION_SECRET=any_random_32_char_string

# ── External APIs (optional) ──────────────────────────────────────────────────
# Free token from https://www.courtlistener.com/sign-in/
COURTLISTENER_API_TOKEN=optional_free_token_from_courtlistener

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
